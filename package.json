{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "format:typescript": "prettier --write \"**/*.+(js|ts|json|tsx|jsx|vue)\"",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "apexcharts": "^4.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue3-apexcharts": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  }
}
